{
  "name": "nextjs-shadcn",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0 --turbopack",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "bunx tsc --noEmit && bunx eslint . --max-warnings=0",
    "format": "bunx biome format --write",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev --name init",
    "db:migrate:deploy": "bunx prisma migrate deploy",
    "db:push": "bunx prisma db push",
    "db:seed": "bunx prisma db seed",
    "db:studio": "bunx prisma studio",
    "db:setup": "bunx prisma generate && bunx prisma migrate dev --name init && bunx prisma db seed",
    "postinstall": "prisma generate",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "setup:imagekit": "bun run setup-imagekit-sync.ts",
    "sync-images": "bun run scripts/sync-drive-to-imagekit.ts",
    "sync-images:watch": "bun run --watch scripts/sync-drive-to-imagekit.ts",
    "sync-status": "bun run scripts/sync-status.ts",
    "sync-help": "bun run scripts/sync-help.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "6.18.0",
    "@react-email/components": "^0.5.7",
    "@stripe/react-stripe-js": "^5.2.0",
    "@stripe/stripe-js": "^8.1.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^11.0.0",
    "googleapis": "^164.1.0",
    "imagekit": "^6.0.0",
    "lucide-react": "^0.475.0",
    "next": "15.5.6",
    "next-auth": "^4.24.7",
    "prisma": "6.18.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-email": "^4.3.1",
    "resend": "^6.2.0",
    "same-runtime": "^0.0.1",
    "stripe": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@eslint/eslintrc": "^3.3.1",
    "@next/bundle-analyzer": "^15.0.0",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.17.50",
    "@types/react": "^18.3.22",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^9.27.0",
    "eslint-plugin-import": "^2.32.0",
    "happy-dom": "^20.0.10",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vitest": "^4.0.7"
  }
}
