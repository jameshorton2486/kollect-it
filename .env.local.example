# =============================================================================
# KOLLECT-IT MARKETPLACE - LOCAL DEVELOPMENT ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env.local for local development
# The .env.local file overrides values in .env for development
# NEVER commit .env.local to version control - it contains sensitive credentials
# =============================================================================

# --- Core Application (Development) ---
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Authentication (NextAuth.js) ---
# For local development, generate: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=dev-secret-key-min-32-characters-for-development-only

# --- Database (PostgreSQL via Supabase - Development/Staging) ---
# Pooled connection for app queries (Port 6543 with pgbouncer)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.okthcpumncidcihdhgea.supabase.co:6543/postgres?pgbouncer=true

# Direct connection for migrations (Port 5432)
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.okthcpumncidcihdhgea.supabase.co:5432/postgres

# --- Stripe Payment Processing (Test Mode) ---
STRIPE_SECRET_KEY=sk_test_your_test_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_test_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_test_publishable_key_here

# --- Email Notifications (Resend - Development) ---
RESEND_API_KEY=re_your_development_api_key_here
EMAIL_FROM=Kollect-It Dev <dev@localhost>
ADMIN_EMAIL=dev-admin@localhost

# --- Image Hosting (ImageKit - Development) ---
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_1MwR2t3I95qAJXc72h1DzbbLLZU=
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/kollectit
IMAGEKIT_PUBLIC_KEY=public_1MwR2t3I95qAJXc72h1DzbbLLZU=
IMAGEKIT_PRIVATE_KEY=your_private_key_from_imagekit_dashboard
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/kollectit

# --- Google Drive to ImageKit Sync ---
# GOOGLE_DRIVE_FOLDER_ID: Get from Google Drive folder URL (the long ID after /folders/)
# Example: https://drive.google.com/drive/folders/1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p → 1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id_here
# GOOGLE_APPLICATION_CREDENTIALS: Path to service account JSON file
# Download from Google Cloud Console → API & Services → Service Accounts → Keys → Add Key (JSON)
# Place the downloaded file in project root and reference it here
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json
# WEBHOOK_SECRET: For securing the /api/sync-images endpoint
# Generate a strong random secret: openssl rand -base64 32
# Minimum 32 characters recommended for security
WEBHOOK_SECRET=your_webhook_secret_min_32_characters_here

# --- Supabase API Keys (Development/Staging) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_development_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_development_service_role_key_here

# --- Debug/Development Options ---
# Uncomment to enable verbose logging
# DEBUG=*
