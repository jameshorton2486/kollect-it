# =============================================================================
# KOLLECT-IT MARKETPLACE - ENVIRONMENT VARIABLES
# =============================================================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control - it contains sensitive credentials
# =============================================================================

# --- Core Application ---
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=https://kollect-it.com

# --- Authentication (NextAuth.js) ---
# Generate NEXTAUTH_SECRET: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-min-32-characters

# --- Database (PostgreSQL via Supabase) ---
# Pooled connection for app queries (Port 6543 with pgbouncer)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.okthcpumncidcihdhgea.supabase.co:6543/postgres?pgbouncer=true

# Direct connection for migrations (Port 5432) - Optional for local development
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.okthcpumncidcihdhgea.supabase.co:5432/postgres

# --- Stripe Payment Processing ---
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# --- Email Notifications (Resend) ---
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Kollect-It <noreply@kollect-it.com>
ADMIN_EMAIL=admin@kollect-it.com

# --- Image Hosting (ImageKit) ---
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=public_your_public_key_here
NEXT_PUBLIC_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-id/
IMAGEKIT_PRIVATE_KEY=private_your_private_key_here

# --- Optional: Supabase API Keys (if using Supabase features beyond Postgres) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
